# --- Servidor ---
PORT=3000

# --- Pinecone ---
PINECONE_API_KEY=
# El indice debe existir y tener dimension 1536 (ada-002 / text-embedding-3-small), metrica cosine
PINECONE_INDEX=mi-indice
# Namespace por defecto (el usuario puede sobreescribirlo desde el formulario)
PINECONE_NAMESPACE=excel-drive

# --- Embeddings (Azure OpenAI) ---
# Clave del recurso de Azure Cognitive Services / OpenAI
AZURE_OPENAI_API_KEY=
# Endpoint base del recurso (SIN la ruta /openai/deployments/...)
AZURE_OPENAI_ENDPOINT=https://lau-tutores-resource.cognitiveservices.azure.com
# Nombre del deployment del modelo de embeddings (1536 dims)
AZURE_OPENAI_DEPLOYMENT=text-embed-ada-tutores
# Version de la API
AZURE_OPENAI_API_VERSION=2023-05-15